# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# IDE
.vscode/

# Ignore compiled binaries under examples (typically extensionless).
examples/**/*
!examples/**/
!examples/**/*.*

# Go cache
.gocache
