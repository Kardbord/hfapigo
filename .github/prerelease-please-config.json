{
  "packages": {
    ".": {
      "release-type": "go",
      "version-file": "internal/sdkversion/version.go",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true,
      "skip-changelog": false,
      "draft": false,
      "draft-pull-request": true,
      "include-v-in-tag": true,
      "include-v-in-release-name": true,
      "always-update": true,
      "versioning": "prerelease",
      "prerelease": true,
      "prerelease-type": "rc",
      "pull-request-footer": "This PR was generated by Release Please. The PR title and body are load-bearing — do not edit them manually."
    }
  }
}
